# Server
AGENT_SDK_PORT=20001
# Optional bearer token for incoming requests. Leave empty for local demos.
AGENT_SDK_API_KEY=

# Claude / Anthropic-compatible upstream
ANTHROPIC_AUTH_TOKEN=replace-with-your-api-key
# Optional. Example: https://api.anthropic.com
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional runtime behavior
APP_LANG=en
STRIP_THINKING_BLOCKS=0
AGENT_SDK_IDLE_TIMEOUT_MS=180000
AGENT_SDK_ANSWER_TIMEOUT_MS=300000

# Icon Designer sample
# mock works without credentials; use tencent, dmxapi, or auto after configuring credentials.
ICON_DESIGNER_PROVIDER=mock
ICON_DESIGNER_OUTPUT_DIR=.generated/icon-designer

# Optional DMXAPI provider
DMX_API_KEY=

# Optional Tencent Cloud provider
TENCENT_APP_ID=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SUB_APP_ID=

# Optional Cloudflare R2 publishing. Without these, generated files stay local.
UPLOAD_PROVIDER=local
PUBLIC_BASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=
