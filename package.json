{
  "name": "skills-sdk-server",
  "version": "0.1.0",
  "description": "Open-source Bun server wrapper for Claude Agent SDK with SSE, interactive questions, and a sample skill app.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "bun build --target=bun --outdir dist src/server.ts",
    "start": "bun dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.89",
    "js-yaml": "^4.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.4",
    "typescript": "^5.7.2"
  }
}
